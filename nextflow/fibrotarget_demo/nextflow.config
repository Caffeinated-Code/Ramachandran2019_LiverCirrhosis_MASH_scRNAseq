manifest {
  name = 'fibrotarget-liver-demo'
  description = 'Standalone demo pipeline for liver fibrosis single-cell target discovery'
}

params {
  input = "${projectDir}/assets/demo_samplesheet.csv"
  outdir = "${projectDir}/../../reports/nextflow_demo"
}

process {
  executor = 'local'
  cpus = 1
  memory = '2 GB'
}

profiles {
  local {
    process.executor = 'local'
  }

  aws {
    process.executor = 'awsbatch'
    process.queue = System.getenv('AWS_BATCH_QUEUE') ?: 'replace-me'
    process.container = System.getenv('PIPELINE_IMAGE') ?: 'replace-me.dkr.ecr.us-west-2.amazonaws.com/fibrotarget-liver:latest'
    workDir = System.getenv('NXF_WORK') ?: 's3://replace-me/fibrotarget-liver/work'
    aws.region = System.getenv('AWS_REGION') ?: 'us-west-2'
  }
}
